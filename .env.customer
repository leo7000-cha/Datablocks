# ==============================================================================
# DLM 고객사 배포 환경변수
# 이 파일만 고객사 환경에 맞게 수정하면 됩니다
# ==============================================================================

# --- 고객사 MariaDB 접속정보 ---
# ★ 아래 IP/포트를 고객사 DB 서버로 변경하세요
SPRING_DATASOURCE_URL=jdbc:mariadb://192.168.1.100:3306/cotdl?serverTimezone=UTC&autoReconnect=true&allowMultiQueries=true

# --- DLM 설정 ---
SPRING_PROFILES_ACTIVE=local
JASYPT_ENCRYPTOR_PASSWORD=datablocks

# --- ★ 서비스 포트 (기존 서비스와 충돌 시 변경) ---
DLM_PORT=8080
AI_PORT=8000

# --- Privacy-AI DB 접속정보 ---
# ★ DLM과 같은 DB를 사용합니다. IP를 고객사 DB 서버로 변경하세요
PRIVACY_AI_DB_HOST=192.168.1.100
PRIVACY_AI_DB_PORT=3306
PRIVACY_AI_DB_NAME=cotdl
PRIVACY_AI_DB_USER=cotdl
PRIVACY_AI_DB_PASSWORD=!Dlm1234

# --- Privacy-AI 내부 설정 (수정 불필요) ---
PRIVACY_AI_DLM_API_URL=http://dlm:8080
PRIVACY_AI_DEBUG=false

# --- Mail (선택) ---
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=d40e3734a875c9
MAIL_PASSWORD=05466edb6f3d9e

# --- LLM 설정 (선택) ---
PRIVACY_AI_LLM_ENABLED=false
PRIVACY_AI_LLM_API_URL=
PRIVACY_AI_LLM_API_KEY=
PRIVACY_AI_LLM_MODEL=
