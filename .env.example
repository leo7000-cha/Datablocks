# ==============================================================================
# DLM Docker Compose Environment Variables
# ==============================================================================
# 이 파일을 .env로 복사한 후 값을 수정하세요:
#   cp .env.example .env
# ==============================================================================

# --- MariaDB ---
MARIADB_ROOT_PASSWORD=your_password_here

# --- DLM Spring Boot ---
SPRING_PROFILES_ACTIVE=local
SPRING_DATASOURCE_URL=jdbc:mariadb://dlm-mariadb:3306/cotdl?serverTimezone=UTC&autoReconnect=true&allowMultiQueries=true
JASYPT_ENCRYPTOR_PASSWORD=your_jasypt_key_here

# --- DLM Privacy AI ---
PRIVACY_AI_DB_HOST=dlm-mariadb
PRIVACY_AI_DB_PORT=3306
PRIVACY_AI_DB_NAME=cotdl
PRIVACY_AI_DB_USER=cotdl
PRIVACY_AI_DB_PASSWORD=your_password_here
PRIVACY_AI_DLM_API_URL=http://dlm:8080
PRIVACY_AI_DEBUG=false

# --- LLM Settings (Privacy AI) ---
PRIVACY_AI_LLM_ENABLED=false
PRIVACY_AI_LLM_API_URL=
PRIVACY_AI_LLM_API_KEY=
PRIVACY_AI_LLM_MODEL=
