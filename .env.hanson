# --- ★ 고객사 MariaDB 접속정보 ---
# 기존 Docker 컨테이너 'mariadb'에 접속 (dlm-network 으로 연결)
SPRING_DATASOURCE_URL=jdbc:mariadb://mariadb:3306/cotdl?serverTimezone=UTC&autoReconnect=true&allowMultiQueries=true
JASYPT_ENCRYPTOR_PASSWORD=datablocks
SPRING_PROFILES_ACTIVE=local

# --- ★ 기존 MariaDB 컨테이너 이름 ---
MARIADB_CONTAINER=mariadb

# --- ★ 서비스 포트 (기존 서비스와 충돌 시 변경) ---
DLM_PORT=8082
AI_PORT=8000

# --- ★ Privacy-AI DB 접속정보 ---
PRIVACY_AI_DB_HOST=mariadb
PRIVACY_AI_DB_PORT=3306
PRIVACY_AI_DB_NAME=cotdl
PRIVACY_AI_DB_USER=cotdl
PRIVACY_AI_DB_PASSWORD=!Dlm1234

# --- Privacy-AI 내부 설정 (수정 불필요) ---
PRIVACY_AI_DLM_API_URL=http://dlm:8080
PRIVACY_AI_DEBUG=false

# --- Mail (선택) ---
MAIL_HOST=sandbox.smtp.mailtrap.io
