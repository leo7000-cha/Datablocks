# ==============================================================================
# Datablocks Docker Monorepo .gitignore
# ==============================================================================

# --- Environment / Secrets ---
.env
*.env.local

# --- DLM 기존 Git repo (서브디렉토리 repo 무시) ---
DLM/.git

# --- IDE ---
.idea/
*.iml
*.ipr
*.iws
.vscode/
*.swp
*.swo

# --- OS ---
.DS_Store
Thumbs.db

# --- Java / Gradle Build ---
DLM/build/
DLM/dlm-agent/build/
DLM/dlm-aop-sdk/build/
DLM/target/
DLM/bin/
DLM/.gradle/
*.class
*.jar
*.war
*.zip
*.tar.gz
*.rpm
DLM/dlm-agent/bin/

# --- Python ---
DLM-Privacy-AI/__pycache__/
DLM-Privacy-AI/**/__pycache__/
DLM-Privacy-AI/*.pyc
DLM-Privacy-AI/.venv/
DLM-Privacy-AI/venv/

# --- Docker volumes / data ---
mariadb/data/

# --- DB backup dumps (운영 데이터 + repo bloat 방지) ---
# 디렉터리 자체는 추적 — 그 안의 dump 파일 패턴만 무시
# (디렉터리를 ignore 하면 negation 이 안 되므로 dump 확장자만 명시)
database/backup/*.sql
database/backup/*.sql.gz
database/backup/*.sql.bz2
database/backup/*.tar.gz
deploy/*/database/backup/*.sql
deploy/*/database/backup/*.sql.gz
deploy/*/database/backup/*.sql.bz2
deploy/*/database/backup/*.tar.gz

# --- Logs ---
*.log
*.log.*
logs/

# --- Claude ---
.claude/
