# ==============================================================================
# Datablocks Docker Monorepo .gitignore
# ==============================================================================

# --- Environment / Secrets ---
.env
*.env.local

# --- DLM 기존 Git repo (서브디렉토리 repo 무시) ---
DLM/.git

# --- IDE ---
.idea/
*.iml
*.ipr
*.iws
.vscode/
*.swp
*.swo

# --- OS ---
.DS_Store
Thumbs.db

# --- Java / Gradle Build ---
DLM/build/
DLM/dlm-agent/build/
DLM/dlm-aop-sdk/build/
DLM/target/
DLM/bin/
DLM/.gradle/
*.class
*.jar
*.war
*.zip
*.tar.gz
*.rpm
DLM/dlm-agent/bin/

# --- Python ---
DLM-Privacy-AI/__pycache__/
DLM-Privacy-AI/**/__pycache__/
DLM-Privacy-AI/*.pyc
DLM-Privacy-AI/.venv/
DLM-Privacy-AI/venv/

# --- Docker volumes / data ---
mariadb/data/

# --- DB backup dumps (운영 데이터 + repo bloat 방지) ---
database/backup/
deploy/*/database/backup/
# 단, 백업 가이드/README 같은 텍스트 문서는 git 추적
!database/backup/*.txt
!database/backup/*.md
!deploy/*/database/backup/*.txt
!deploy/*/database/backup/*.md

# --- Logs ---
*.log
*.log.*
logs/

# --- Claude ---
.claude/
