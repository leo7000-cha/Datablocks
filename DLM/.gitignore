#---------------------------------------------------
# IntelliJ IDEA
#---------------------------------------------------
.idea/             # IntelliJ IDEA 설정 파일
*.iml              # 프로젝트 모듈 파일
*.ipr
*.iws

#---------------------------------------------------
# Java / Maven / Gradle
#---------------------------------------------------
# 빌드 출력 폴더 및 파일
/target/           # Maven 빌드 결과 폴더
/build/            # Gradle 빌드 결과 폴더
/bin/
*.class

# 컴파일된 라이브러리 및 배포 파일
*.jar
*.war
*.zip
*.tar
*.tar.gz
*.tgz

# 로그 파일
*.log
*.log.1
logs/

# 임시 파일
tmp/

# Maven/Gradle 캐시 및 래퍼
.gradle/
.m2/repository/

#---------------------------------------------------
# Spring Boot Specific
#---------------------------------------------------
# 환경 설정 파일 및 보안 정보
# 실제 환경 정보나 보안 키가 들어갈 수 있습니다.
# (예: application-prod.properties, database_key.pem 등)
# .properties 파일 전체를 제외하지 말고, 민감한 파일만 제외하는 것을 권장합니다.
# /src/main/resources/application-*.properties
# /src/main/resources/application-*.yml
# /src/main/resources/secret/

#---------------------------------------------------
# Tomcat work directory
#---------------------------------------------------
work/

#---------------------------------------------------
# Documents
#---------------------------------------------------
*.docx
*.pptx
