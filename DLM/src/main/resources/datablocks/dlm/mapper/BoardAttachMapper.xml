<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="datablocks.dlm.mapper.BoardAttachMapper">

	<insert id="insert">
		insert into COTDL.tbl_attach (uuid, uploadpath, filename,
		filetype, bno)
		values (#{uuid}, #{uploadPath}, #{fileName},
		#{fileType}, #{bno} )
	</insert>

	<delete id="delete">

		delete from COTDL.tbl_attach where uuid = #{uuid}

	</delete>

	<select id="findByBno"
		resultType="datablocks.dlm.domain.BoardAttachVO">
		select * from COTDL.tbl_attach where bno = #{bno}
	</select>

	<delete id="deleteAll">

		delete COTDL.tbl_attach where bno = #{bno}

	</delete>

	<select id="getOldFiles"
		resultType="datablocks.dlm.domain.BoardAttachVO">

		select * from COTDL.tbl_attach where uploadpath =  DATE_FORMAT(NOW() -1 ,'yyyy\mm\dd')

	</select>


</mapper>
