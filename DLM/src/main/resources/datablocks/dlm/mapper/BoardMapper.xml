<select id="getListWithPaging" resultType="datablocks.dlm.domain.BoardVO">
  <![CDATA[
      select /*+INDEX_DESC(cotdl.tbl_board pk_board) */
         bno, title, content, writer, regdate, updatedate, replycnt
      from 
        cotdl.tbl_board
      where 
  ]]>

  <include refid="criteria"></include> 
      
  <![CDATA[
        order by bno
		limit #{offset}, #{amount}
  ]]>
  </select>

  
  

  <select id="getTotalCount" resultType="int">
  select count(*) from cotdl.tbl_board where 
  
    <include refid="criteria"></include> 
    
  bno > 0  
  
  </select>
  
  <update id="updateReplyCnt">
    update cotdl.tbl_board set replycnt = replycnt + #{amount} where bno = #{bno}
  </update>  

</mapper>
