<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="datablocks.dlm.mapper.BoardMapper">

	<sql id="criteria">
		<trim prefix="(" suffix=") AND " prefixOverrides="OR">
			<foreach item='type' collection="typeArr">
				<trim prefix="OR">
					<choose>
						<when test="type == 'T'.toString()">
							title like concat('%',#{keyword},'%')
						</when>
						<when test="type == 'C'.toString()">
							content like concat('%',#{keyword},'%')
						</when>
						<when test="type == 'W'.toString()">
							writer like concat('%',#{keyword},'%')
						</when>
					</choose>
				</trim>
			</foreach>
		</trim>
	</sql>

	<select id="getList" resultType="datablocks.dlm.domain.BoardVO">
	<![CDATA[
		select * from cotdl.tbl_board where
		bno > 0 and  ROWNUM <= 100
		]]>
	</select>

	<insert id="insert">
		insert into cotdl.tbl_board (bno,title,content,writer)
		values (seq_board.nextval, #{title}, #{content}, #{writer})
	</insert>

	<insert id="insertSelectKey">

		<selectKey keyProperty="bno" order="BEFORE"
			resultType="long">
			select seq_board.nextval from dual
		</selectKey>

		insert into cotdl.tbl_board (bno,title,content, writer)
		values (#{bno},
		#{title}, #{content}, #{writer})
	</insert>

	<select id="read" resultType="datablocks.dlm.domain.BoardVO">
		select * from cotdl.tbl_board where bno =
		#{bno}
	</select>


	<delete id="delete">
		delete cotdl.tbl_board where bno = #{bno}
	</delete>
	
	<update id="update">
		update cotdl.tbl_board
		set title= #{title},
		content=#{content},
		writer = #{writer},
		updateDate = NOW()
		where bno = #{bno}
	</update>

