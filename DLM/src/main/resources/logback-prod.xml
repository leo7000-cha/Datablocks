<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true">
    <property name="LOGS_PATH" value="/app/logs"/> <!-- Docker 볼륨 경로 -->
    <property name="LOG_PATTERN" value="[%d{yyyy-MM-dd HH:mm:ss.SSS}][%thread] %-5level %logger{36} - %msg%n"/>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOGS_PATH}/app.log</file>
        <encoder><pattern>${LOG_PATTERN}</pattern></encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOGS_PATH}/app.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>10GB</totalSizeCap>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
    </appender>

    <!-- 콘솔 미사용 -->
    <root level="WARN">
        <appender-ref ref="FILE"/>
    </root>

    <!-- 패키지별 필요시 -->
    <logger name="datablocks.dlm" level="WARN" additivity="false">
        <appender-ref ref="FILE"/>
    </logger>
</configuration>
