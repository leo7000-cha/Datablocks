# ==============================================================================
# DLM 환경변수 — 한국손해보험 (PROD: OS 설치형 MariaDB)
# ==============================================================================
# ★ MariaDB 가 호스트 OS 에 직접 설치됨 (Docker 컨테이너 아님)
# ★ 컨테이너 → 호스트 DB 접속은 host.docker.internal (host-gateway) 사용

# --- ★ 호스트 MariaDB 접속정보 ---
# host.docker.internal : docker-compose 의 extra_hosts 매핑으로 호스트 IP 로 해석됨
# 포트/DB/계정은 OS 설치된 MariaDB 에 실제 구성된 값으로 맞춰주세요
SPRING_DATASOURCE_URL=jdbc:mariadb://host.docker.internal:3306/cotdl?serverTimezone=UTC&autoReconnect=true&allowMultiQueries=true
JASYPT_ENCRYPTOR_PASSWORD=datablocks
SPRING_PROFILES_ACTIVE=local

# --- ★ MariaDB 호스트 (배포 스크립트가 연결 테스트 용으로 사용) ---
# 기본값 host.docker.internal (권장) — 필요 시 호스트 실제 IP 로 변경 가능
MARIADB_HOST=host.docker.internal
MARIADB_PORT=3306

# --- ★ 서비스 포트 (기존 서비스와 충돌 시 변경) ---
DLM_PORT=8082
AI_PORT=8000

# --- ★ Privacy-AI DB 접속정보 (OS MariaDB) ---
PRIVACY_AI_DB_HOST=host.docker.internal
PRIVACY_AI_DB_PORT=3306
PRIVACY_AI_DB_NAME=cotdl
PRIVACY_AI_DB_USER=cotdl
PRIVACY_AI_DB_PASSWORD=!Dlm1234

# --- Privacy-AI 내부 설정 ---
# Privacy-AI 는 compose 기본 네트워크로 DLM 컨테이너에 직접 접근
PRIVACY_AI_DLM_API_URL=http://dlm:8080
PRIVACY_AI_DEBUG=false

# --- Mail (선택) ---
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# --- LLM 설정 (선택) ---
PRIVACY_AI_LLM_ENABLED=false
PRIVACY_AI_LLM_API_URL=
PRIVACY_AI_LLM_API_KEY=
PRIVACY_AI_LLM_MODEL=
