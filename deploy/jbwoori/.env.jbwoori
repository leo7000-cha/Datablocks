# ==============================================================================
# DLM 환경변수 — JB우리캐피탈
# ==============================================================================
# ★ MariaDB: 호스트 OS (Rocky 9)에 직접 설치
# ★ host.docker.internal = 호스트 OS (Docker가 자동으로 매핑)

# --- ★ 고객사 MariaDB 접속정보 ---
SPRING_DATASOURCE_URL=jdbc:mariadb://host.docker.internal:3306/cotdl?serverTimezone=UTC&autoReconnect=true&allowMultiQueries=true
SPRING_DATASOURCE_USERNAME=cotdl
SPRING_DATASOURCE_PASSWORD=!Dlm1234
SPRING_PROFILES_ACTIVE=local,ssl

# --- ★ 서비스 포트 (기존 서비스와 충돌 시 변경) ---
# 기본: HTTPS 8443 (메인) + HTTP 8080 (자동 리다이렉트)
DLM_PORT=8080
DLM_PORT_HTTPS=8443
AI_PORT=8000

# --- ★ Privacy-AI DB 접속정보 ---
PRIVACY_AI_DB_HOST=host.docker.internal
PRIVACY_AI_DB_PORT=3306
PRIVACY_AI_DB_NAME=cotdl
PRIVACY_AI_DB_USER=cotdl
PRIVACY_AI_DB_PASSWORD=!Dlm1234

# --- Privacy-AI 내부 설정 (수정 불필요) ---
PRIVACY_AI_DLM_API_URL=http://dlm:8080
PRIVACY_AI_DEBUG=false

# --- Mail (선택) ---
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# --- LLM 설정 (선택) ---
PRIVACY_AI_LLM_ENABLED=false
PRIVACY_AI_LLM_API_URL=
PRIVACY_AI_LLM_API_KEY=
PRIVACY_AI_LLM_MODEL=

# ==============================================================================
# X-Audit Storage Routing (감사로그 저장 DB)
# ==============================================================================
# TBL_PIIDATABASE.db=XAUDIT_DB 엔트리가 물리적 저장소를 결정.
# 최초 기동 시 Primary DS 정보로 자동 등록 → 기본은 DLM 내부 DB.
# 고객사 별도 DB 로 전환: UI 에서 XAUDIT_DB 엔트리만 수정 후 재기동.
XAUDIT_STORAGE_POOL_SIZE=4
XAUDIT_STORAGE_RETRY_INIT_SECONDS=60

# ==============================================================================
# HTTPS / SSL 설정 (기본 활성)
# ==============================================================================
# 동작: 8443 HTTPS 메인 서비스 + 8080 HTTP → 8443 자동 리다이렉트
# 인증서: certs/dlm-keystore.p12 (자체 서명, 10년 유효, alias=dlm-keystore)
#
# 운영 인증서로 교체 시:
#   1. certs/dlm-keystore.p12 를 고객사 발급 인증서로 교체 (certs/README.md 참조)
#   2. 아래 SERVER_SSL_KEY_STORE_PASSWORD / SERVER_SSL_KEY_PASSWORD 를 실값으로 변경
#   3. SERVER_SSL_KEY_ALIAS 를 새 keystore 의 alias 로 변경
#   4. docker compose --env-file .env.jbwoori -f docker-compose.jbwoori.yml restart dlm
#
# HTTPS 비활성화 (HTTP 8080 단일 모드):
#   - SPRING_PROFILES_ACTIVE 를 local 로 되돌리고 아래 SERVER_* 블록 주석 처리
#   - docker-compose.jbwoori.yml 의 8443 포트 / certs 볼륨 라인도 주석 처리
#
# ※ LOGGING_CONFIG 는 필수 — application.properties 가 profile 이름을 직접
#   logback 파일명에 치환하므로 local,ssl 조합 시 명시적 경로 지정 필요.

SERVER_PORT=8443
SERVER_SSL_ENABLED=true
SERVER_SSL_KEY_STORE=file:/etc/ssl/dlm-keystore.p12
SERVER_SSL_KEY_STORE_TYPE=PKCS12
SERVER_SSL_KEY_STORE_PASSWORD=dlmssl
SERVER_SSL_KEY_ALIAS=dlm-keystore
SERVER_SSL_KEY_PASSWORD=dlmssl
LOGGING_CONFIG=classpath:logback-local.xml
